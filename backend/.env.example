# Database
DATABASE_URL=postgresql://veil:veil@localhost:5432/veil

# MinIO
MINIO_ENDPOINT=localhost:9000
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=minioadmin
MINIO_BUCKET=veil-storage
MINIO_SECURE=false

# JWT Secrets
VEIL_SECRET_KEY=your-super-secret-key-change-this-in-production-256-bits
VEIL_REFRESH_SECRET_KEY=your-refresh-secret-key-change-this-in-production-256-bits

# Admin
VEIL_ADMIN_KEY=your-admin-secret-key-change-this

# CORS
VEIL_ALLOWED_ORIGINS=http://localhost:5173,http://127.0.0.1:5173

# Limits
MAX_FILE_SIZE=104857600
MAX_FILES_PER_USER=1000
