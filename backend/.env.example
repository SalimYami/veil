# VEIL - Configuration des variables d'environnement
# Copiez ce fichier en '.env' et modifiez les valeurs

# Clés de signature JWT (Générez des chaînes aléatoires longues)
VEIL_SECRET_KEY=votre-cle-secrete-ici
VEIL_REFRESH_SECRET_KEY=votre-cle-de-refresh-ici

# Clé de promotion Administrateur
VEIL_ADMIN_KEY=veil-admin-1234
