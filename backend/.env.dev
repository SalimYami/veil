# ═══════════════════════════════════════════════════
# VEIL Backend — Dev SQLite (sans Docker)
# Utilise SQLite local + stockage local simulé
# ═══════════════════════════════════════════════════

# ── Database SQLite locale ─────────────────────────
DATABASE_URL=sqlite:///./dev_local.db

# ── MinIO (désactivé / mock) ───────────────────────
MINIO_ENDPOINT=localhost:9000
MINIO_EXTERNAL_ENDPOINT=http://localhost:9000
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=changeme-use-a-strong-password
MINIO_BUCKET=veil-storage
MINIO_REGION=us-east-1
MINIO_SECURE=False

# ── Redis (désactivé) ─────────────────────────────
REDIS_URL=redis://localhost:6379/0

# ── JWT Secrets ───────────────────────────────────
VEIL_SECRET_KEY=dev-super-secret-key-minimum-32-chars-for-local
VEIL_REFRESH_SECRET_KEY=dev-refresh-secret-key-minimum-32-chars-ok

# ── Admin ─────────────────────────────────────────
VEIL_ADMIN_KEY=veil-admin-dev-2024

# ── Anti-énumération ──────────────────────────────
SALT_HMAC_SECRET=dev-hmac-secret-minimum-32-characters-here

# ── CORS ──────────────────────────────────────────
VEIL_ALLOWED_ORIGINS=http://localhost:5173,http://localhost:5174,http://127.0.0.1:5173,http://127.0.0.1:5174

# ── Limits ────────────────────────────────────────
MAX_FILE_SIZE=104857600
MAX_FILES_PER_USER=1000
