# ═══════════════════════════════════════════════════
# VEIL — Environment Variables
# ═══════════════════════════════════════════════════
# Copy this file to .env and fill in real values:
#   cp .env.example .env
#
# NEVER commit .env to git!
# ═══════════════════════════════════════════════════

# ── PostgreSQL ────────────────────────────────────
POSTGRES_USER=veil
POSTGRES_PASSWORD=changeme-use-a-strong-password
POSTGRES_DB=veil

# ── MinIO Object Storage ─────────────────────────
MINIO_ROOT_USER=minioadmin
MINIO_ROOT_PASSWORD=changeme-use-a-strong-password
MINIO_BUCKET=veil-storage
MINIO_REGION=us-east-1

# ── Backend (FastAPI) ────────────────────────────
VEIL_SECRET_KEY=generate-a-256-bit-secret-key
VEIL_REFRESH_SECRET_KEY=generate-another-256-bit-secret-key
VEIL_ADMIN_KEY=generate-an-admin-secret-key
VEIL_ALLOWED_ORIGINS=http://localhost,http://localhost:5173
MAX_FILE_SIZE=104857600
MAX_FILES_PER_USER=1000
